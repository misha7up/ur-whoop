<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        ========== BLUETOOTH РАЗРЕШЕНИЯ ==========
        До Android 12 (API < 31) нужны BLUETOOTH + ACCESS_FINE_LOCATION
        С Android 12 (API >= 31) нужны BLUETOOTH_CONNECT + BLUETOOTH_SCAN
    -->

    <!-- Интернет: карта UREMONT открывается во внешнем браузере -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Проверка наличия сети (для QR-кода при офлайне) -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Для API <= 30: базовые Bluetooth разрешения -->
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />

    <!-- Для API <= 30: геолокация нужна для поиска BT-устройств -->
    <uses-permission
        android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.ACCESS_COARSE_LOCATION"
        android:maxSdkVersion="30" />

    <!-- Для API >= 31: новые разрешения Bluetooth (Android 12+) -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />

    <!-- Объявляем, что приложению нужен Bluetooth-адаптер -->
    <uses-feature
        android:name="android.hardware.bluetooth"
        android:required="true" />

    <application
        android:name=".UremontApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.UremontBluetooth">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            FileProvider нужен для безопасной передачи PDF-файлов
            через Intent.ACTION_SEND в другие приложения (WhatsApp, Telegram, Почта...).
            authority = applicationId + ".fileprovider"
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
